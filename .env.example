# Hugging Face の Write トークン（学習・Hub へのアップロードに使用）
# このファイルをコピーして `.env` という名前で保存し、値を埋めてください。
# `.env` は .gitignore によりコミットされません。

HF_TOKEN=hf_ここにあなたのトークンを貼る
HF_LORA_REPO=あなたのユーザー名/空のモデルリポジトリ名

# 下記は原則変更しないこと。学習対象のベースモデル名はUnsloth公式のものを使用。
# HF_MODEL_REPO=unsloth/Llama-3.2-3B-Instruct-bnb-4bit

# 学習用 JSONL。未設定なら params.yaml の dataset_jsonl（既定 data/dataset.jsonl）。
# TRAINING_DATASET_PATH=C:\path\to\my_dataset.jsonl
# TRAINING_DATASET_URL=https://example.com/my_dataset.jsonl
# 形式（未設定なら params.yaml の dataset_format）。例: alpaca | messages | text | prompt_completion | auto
# TRAINING_DATASET_FORMAT=auto
